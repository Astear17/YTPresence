{
  "name": "ytpresence",
  "version": "0.1.0",
  "private": true,
  "description": "Windows tray app and Chromium extension for YouTube Music Discord Rich Presence.",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "corepack pnpm --filter @ytpresence/desktop dev",
    "build": "corepack pnpm -r build",
    "package:desktop": "corepack pnpm --filter @ytpresence/desktop package:desktop",
    "lint": "corepack pnpm -r lint",
    "typecheck": "corepack pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "pnpm": "9.15.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0"
  }
}
